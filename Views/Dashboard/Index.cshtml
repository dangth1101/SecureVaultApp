@model SecureVaultApp.ViewModels.UserDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h4 class="card-title mb-4">👋 Welcome, @Model.UserName!</h4>

                <table class="table table-borderless">
                    <tr>
                        <td class="text-muted fw-bold">Username</td>
                        <td>@Model.UserName</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-bold">Email</td>
                        <td>@Model.Email</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-bold">Role</td>
                        <td><span class="badge bg-primary">@Model.Role</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-bold">Department</td>
                        <td><span class="badge bg-secondary">@Model.Department</span></td>
                    </tr>
                </table>

                <form asp-action="Logout" asp-controller="Auth" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </div>
</div>